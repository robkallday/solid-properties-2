---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import LeadForm from '../components/LeadForm.astro';
import Lottie from '../components/Lottie.astro';
---

<Layout
  title="Solid Properties & Investments LLC | We Buy Houses Cash in San Diego"
  description="We buy houses cash in San Diego. Get a fast, fair cash offer for your home. Probate, foreclosure, divorce — no repairs, no commissions, no hassle."
>
  <Navbar />

  <!-- HERO -->
  <section class="relative pt-16 pb-20 md:pt-20 md:pb-24 bg-[#f8f8f8] overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-12 gap-x-10 items-center">
        <!-- Left content -->
        <div class="md:col-span-7">
          <div class="max-w-2xl">
            <p class="uppercase tracking-[3.5px] text-xs font-semibold text-[var(--subtitle-color)] mb-3">SAN DIEGO, CA</p>
            <h1 class="text-[56px] md:text-[68px] leading-[1.05] font-extrabold text-[var(--heading-color)] tracking-[-1.5px]">
              We buy houses<br />
              <span class="text-[var(--main-color)]">faster</span>.
            </h1>
            <p class="mt-6 text-xl md:text-2xl text-[var(--paragraphs-color)] max-w-[42ch]">
              We buy houses cash in San Diego. If you need to sell quickly, we buy homes fast.
              Probate, foreclosure, divorce — get a quick, fair offer today.
            </p>

            <div class="mt-8 flex flex-wrap gap-4">
              <a href="#get-offer" class="inline-flex items-center justify-center px-8 py-4 rounded-2xl bg-[var(--main-color)] text-white text-lg font-semibold hover:bg-[#2f7fc4] transition-all active:scale-[0.985]">
                Get My Cash Offer
              </a>
              <a href="tel:1-619-777-6088" class="inline-flex items-center justify-center px-8 py-4 rounded-2xl border-2 border-[var(--heading-color)] text-[var(--heading-color)] text-lg font-semibold hover:bg-[var(--heading-color)] hover:text-white transition-all">
                Call 619-777-6088
              </a>
            </div>

            <p class="mt-5 text-sm text-[var(--grey)]">No obligation • No repairs needed • Close on your schedule</p>
          </div>
        </div>

        <!-- Right side: prominent lead form -->
        <div class="md:col-span-5 mt-12 md:mt-0">
          <div id="get-offer" class="bg-white rounded-3xl shadow-xl p-8 md:p-9 border border-gray-100">
            <LeadForm
              variant="hero"
              title="Get a Cash Offer Today"
              subtitle="Tell us about your property. We’ll respond within 24 hours."
              buttonText="Get My Cash Offer"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="border-b bg-white py-5">
    <div class="max-w-7xl mx-auto px-6 flex flex-wrap justify-center items-center gap-x-10 gap-y-4 text-sm text-[var(--grey)]">
      <div>No realtor commissions</div>
      <div>•</div>
      <div>Close in as little as 7 days</div>
      <div>•</div>
      <div>Local San Diego team</div>
    </div>
  </div>

  <!-- HOW IT WORKS -->
  <section id="how" class="max-w-7xl mx-auto px-6 pt-20 pb-16">
    <div class="text-center mb-12">
      <p class="subtitle">4 SIMPLE STEPS</p>
      <h2 class="section-title">How it works</h2>
      <p class="paragraph-large max-w-2xl mx-auto">Our process is simple. In just a few steps we’ll make a cash offer and purchase your house fast.</p>
    </div>

    <div class="grid md:grid-cols-4 gap-6">
      {[
        { num: '01', title: 'Send us the address', desc: 'Fill out our form, send us a chat or give us a call. We just need some basic info about your property.' },
        { num: '02', title: 'We review the property', desc: 'After a quick review we’ll contact you with any additional questions. Usually takes less than 48 hours.' },
        { num: '03', title: 'You get a cash offer', desc: 'We send you a no-obligation cash offer for your property. You decide if it works for you.' },
        { num: '04', title: 'House is sold', desc: 'If accepted, we take care of everything and close on the date you choose. No repairs. No hassle.' }
      ].map(step => (
        <div class="group bg-white rounded-3xl p-8 border border-gray-100 hover:border-[var(--main-color)]/30 transition-all">
          <div class="text-5xl font-black text-[var(--main-color)]/10 group-hover:text-[var(--main-color)]/15 transition-colors tabular-nums">{step.num}</div>
          <h3 class="mt-4 text-2xl font-bold text-[var(--heading-color)]">{step.title}</h3>
          <p class="mt-3 text-[15px] leading-relaxed text-[var(--paragraphs-color)]">{step.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CASH VS TRADITIONAL (Comparison Table) -->
  <section class="bg-[#f8f8f8] py-16">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-10">
        <p class="subtitle">THE SMART CHOICE</p>
        <h2 class="section-title">Cash vs. Listing Traditionally</h2>
        <p class="paragraph-large max-w-2xl mx-auto">We can purchase your property with cash or list traditionally. Our cash sale option is the fastest, hassle-free way to sell.</p>
      </div>

      <div class="bg-white rounded-3xl overflow-hidden border border-gray-100 shadow-sm">
        <div class="grid grid-cols-3 text-center font-semibold text-lg py-5 bg-gray-50 text-[var(--heading-color)]">
          <div></div>
          <div class="text-[var(--main-color)]">Cash Sale</div>
          <div>Traditional Sale</div>
        </div>

        {[
          ['No repairs needed', true, false],
          ['No realtor commissions', true, false],
          ['No closing costs', true, false],
          ['No open houses', true, false],
          ['No 30 day escrow', true, false],
          ['Immediate offer', true, false],
          ['Close on your timeline', true, false],
          ['Flexible closing date', true, false],
          ['Certain sale', true, false],
          ['We handle paperwork', true, false],
        ].map(([feature, cash, trad], i) => (
          <div class="grid grid-cols-3 items-center px-8 py-5 border-t text-[15px]" key={i}>
            <div class="font-medium text-[var(--heading-color)]">{feature}</div>
            <div class="flex justify-center">{cash ? <img src="/images/check_blue.svg" alt="Yes" class="w-6 h-6" /> : <img src="/images/grey-x.svg" alt="No" class="w-6 h-6" />}</div>
            <div class="flex justify-center">{trad ? <img src="/images/check_blue.svg" alt="Yes" class="w-6 h-6" /> : <img src="/images/grey-x.svg" alt="No" class="w-6 h-6" />}</div>
          </div>
        ))}
      </div>

      <p class="text-center mt-6 text-sm text-[var(--grey)]">Cash is king when you need speed and certainty.</p>
    </div>
  </section>

  <!-- VIDEO / TESTIMONIAL HIGHLIGHT -->
  <section class="max-w-5xl mx-auto px-6 py-20 text-center">
    <h2 class="section-title mb-4">See what our clients say</h2>
    <p class="paragraph-large max-w-xl mx-auto mb-10">Real stories from San Diego homeowners who sold with us.</p>

    <div class="relative mx-auto max-w-3xl rounded-3xl overflow-hidden shadow-2xl border border-gray-100 bg-black">
      <div class="wistia_responsive_padding" style="padding:56.25% 0 0 0;position:relative;">
        <div class="wistia_responsive_wrapper" style="height:100%;left:0;position:absolute;top:0;width:100%;">
          <iframe 
            src="https://fast.wistia.net/embed/iframe/ytf8j7hb0m?videoFoam=true" 
            title="Client video testimonial" 
            allow="autoplay; fullscreen; picture-in-picture" 
            allowtransparency="true" 
            frameborder="0" 
            scrolling="no" 
            class="wistia_embed" 
            name="wistia_embed" 
            style="height:100%;width:100%;" 
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="max-w-5xl mx-auto px-6 pb-24">
    <div class="text-center mb-12">
      <p class="subtitle">QUESTIONS?</p>
      <h2 class="section-title">Frequently Asked Questions</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {[
        ['What kind of houses do you buy?', 'We typically buy houses that need repair. If your house needs a lot of work, we are interested. Although we don\'t purchase many properties in excellent condition, we can still help you out.'],
        ['How are you able to purchase and close so fast?', 'Since we are a cash buyer, the sale process is quick. We don\'t wait on banks to approve loans or wait for inspection periods and long escrows. This allows us to buy houses fast.'],
        ['How is your company different?', 'We are not a nationwide franchise with thousands of locations and employees. Our company is small and we specialize in southern California. Your calls and messages come to us and we work with you directly. Large companies with an 800 number usually use an out of state call center and pass you around. We are experienced San Diego investors and work with you every step of the way.'],
        ['Do I need to clean or fix my house?', 'Nope, we purchase the property in it\'s current As-Is condition. No need to clean or fix anything. Feel free to leave any trash and unwanted items. Just take what you need and we take care of the rest. We buy houses in AS-IS condition.'],
        ['How fast can you purchase?', 'Typically we need 7-10 days to buy houses. We can close on whichever date works best for you. Let us know your timeline and we can make it happen.'],
        ['My house is in great condition, can you still buy it?', 'We mostly purchase properties in poor condition or in need of repairs. If you need to sell immediately, we can still make you a cash offer. If you\'re not in a hurry and your house is in great condition, we can help sell traditionally.'],
        ['How much would you pay for my house?', 'Since we are a cash buyer, we buy houses at discount. Our cash price is usually about 10% less than what you would get traditionally. For a no obligation quote, fill out our form and we\'ll get back to you with a fair offer.'],
        ['Wouldn’t my property sell for more with a realtor?', 'Your house can sell for more but you don’t walk away with the sale price. Real estate agent commissions are around 6% plus closing cost and any repair requests. You’ll also need to prep your home and make presentable for open houses.'],
        ['Can you renovate and sell my property for me?', 'Yes we can! As long as you\'re not in a hurry and can be out of the house during renovations. We put out the money to clean, fix and renovate. Once we sell the property, these costs are deducted from the sale price.'],
        ['Have I seen your TV commercials?', 'Nope, we are a small local San Diego company and don\'t have the budget for TV advertisements.'],
        ['Are you a We Buy Houses company?', 'We are a real estate solutions company and not one solution fits all. We purchase properties for cash but can also sell your property traditionally.'],
        ['Have I seen your signs in my neighborhood?', 'Nope that was not us. There are lots of San Diego companies that put we buy houses signs in neighborhoods. There are too many polluting the neighborhoods so we decided not to advertise this way.'],
      ].map(([q, a]) => (
        <details class="group bg-white border border-gray-100 rounded-2xl p-7" name={`faq-${i}`}>
          <summary class="font-semibold text-[var(--heading-color)] text-lg cursor-pointer list-none flex justify-between items-center">
            {q}
            <span class="text-2xl text-[var(--main-color)] group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="mt-4 text-[15px] leading-relaxed pr-8">{a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-[var(--heading-color)] py-20 text-center text-white">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-5xl font-bold tracking-tight">Ready to sell your house fast?</h2>
      <p class="mt-4 text-2xl text-white/80">Get a no-obligation cash offer in 24 hours.</p>

      <div class="mt-10">
        <a href="#get-offer" class="inline-block px-10 py-4 rounded-2xl bg-white text-[var(--heading-color)] font-semibold text-lg hover:bg-[var(--golden)] hover:text-black transition-all">
          Get My Cash Offer Now
        </a>
      </div>
      <div class="mt-4 text-white/60 text-sm">Or call us directly at <a href="tel:1-619-777-6088" class="underline hover:text-white">619-777-6088</a></div>
    </div>
  </section>

  <Footer />
</Layout>
