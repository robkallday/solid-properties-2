---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Accessibility Statement | Solid Properties">
  <Navbar />
  <div class="max-w-3xl mx-auto px-6 py-16 prose prose-gray">
    <h1>Accessibility Statement</h1>
    <p>Solid Properties &amp; Investments LLC is committed to making our website accessible to everyone, including people with disabilities.</p>

    <h2>Our Commitment</h2>
    <p>We strive to conform to WCAG 2.2 Level AA standards. We continuously audit and improve the accessibility of our site.</p>

    <h2>Feedback</h2>
    <p>If you experience any accessibility barriers while using this website, please contact us:</p>
    <ul>
      <li>Phone: <a href="tel:1-619-777-6088">619-777-6088</a></li>
      <li>Email: info@solidpropertiesllc.com</li>
    </ul>

    <p>We will respond to accessibility feedback within 5 business days.</p>
  </div>
  <Footer />
</Layout>