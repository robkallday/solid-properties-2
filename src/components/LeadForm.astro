---
interface Props {
  variant?: 'hero' | 'inline' | 'modal';
  title?: string;
  subtitle?: string;
  buttonText?: string;
  showPhone?: boolean;
  class?: string;
}

const {
  variant = 'inline',
  title = 'Get Your Cash Offer',
  subtitle = 'Fill out the form below and we’ll get back to you within 24 hours.',
  buttonText = 'Get Cash Offer',
  showPhone = true,
  class: className = '',
} = Astro.props;
---

<form
  id="lead-form"
  class={`lead-form ${className}`}
  data-variant={variant}
>
  {title && (
    <div class="mb-6">
      <h3 class="text-2xl font-bold text-[var(--heading-color)]">{title}</h3>
      {subtitle && <p class="mt-1.5 text-[15px] text-[var(--paragraphs-color)]">{subtitle}</p>}
    </div>
  )}

  <div class="space-y-4">
    <!-- Property Address -->
    <div>
      <label for="address" class="block text-sm font-medium text-[var(--heading-color)] mb-1.5">
        Property Address <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="address"
        name="address"
        placeholder="123 Main Street, San Diego, CA 92101"
        required
        autocomplete="street-address"
      />
    </div>

    <!-- Email -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label for="email" class="block text-sm font-medium text-[var(--heading-color)] mb-1.5">
          Email Address <span class="text-red-500">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="you@example.com"
          required
          autocomplete="email"
        />
      </div>

      <!-- Phone -->
      {showPhone && (
        <div>
          <label for="phone" class="block text-sm font-medium text-[var(--heading-color)] mb-1.5">
            Phone Number
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder="(619) 555-1234"
            autocomplete="tel"
          />
        </div>
      )}
    </div>

    <!-- Turnstile Widget -->
    <div class="pt-2">
      <div 
        class="cf-turnstile" 
        data-sitekey="0x4AAAAAADYjr8h--vYRDUCx"
        data-callback="onTurnstileSuccess"
        data-expired-callback="onTurnstileExpired"
      ></div>
      <!-- TODO: Replace with your real Cloudflare Turnstile site key -->
    </div>

    <!-- Submit -->
    <button
      type="submit"
      class="submit-button w-full mt-2"
      disabled
    >
      <span class="button-text">{buttonText}</span>
      <span class="button-loading hidden">Sending...</span>
    </button>

    <p class="text-[12px] text-center text-[var(--grey)]">
      No obligation. We respect your privacy.
    </p>
  </div>

  <!-- Success / Error states -->
  <div id="form-success" class="hidden mt-6 p-4 bg-green-50 border border-green-200 text-green-800 rounded-2xl text-center">
    Thank you! We’ve received your information and will contact you shortly.
  </div>

  <div id="form-error" class="hidden mt-6 p-4 bg-red-50 border border-red-200 text-red-800 rounded-2xl text-center text-sm">
    Something went wrong. Please try again or call us at <a href="tel:1-619-777-6088" class="underline">619-777-6088</a>.
  </div>
</form>

<script>
  (function initLeadForm() {
    // Load Cloudflare Turnstile
    function loadTurnstile() {
      if (window.turnstile) return Promise.resolve();

      return new Promise((resolve) => {
        const script = document.createElement('script');
        script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
        script.async = true;
        script.onload = () => resolve();
        document.head.appendChild(script);
      });
    }

    const form = document.getElementById('lead-form');
    if (!form) {
      console.warn('LeadForm: form element not found on this page');
      return;
    }

    const submitBtn = form.querySelector('button[type="submit"]');
    const successEl = document.getElementById('form-success');
    const errorEl = document.getElementById('form-error');
    const buttonText = submitBtn?.querySelector('.button-text');
    const buttonLoading = submitBtn?.querySelector('.button-loading');

    let turnstileToken = '';

    // Proper Turnstile callbacks (wired via data-callback on the widget)
    // @ts-ignore
    window.onTurnstileSuccess = function (token) {
      turnstileToken = token;
      if (submitBtn) {
        submitBtn.disabled = false;
      }
    };

    // @ts-ignore
    window.onTurnstileExpired = function () {
      turnstileToken = '';
      if (submitBtn) {
        submitBtn.disabled = true;
      }
    };

    // Fallback: also try to enable button if Turnstile script loads
    // (in case the widget renders before callbacks are attached)
    loadTurnstile().then(() => {
      // Give Turnstile a moment to render
      setTimeout(() => {
        const responseInput = document.querySelector('[name="cf-turnstile-response"]');
        if (responseInput && responseInput.value && submitBtn) {
          submitBtn.disabled = false;
          turnstileToken = responseInput.value;
        }
      }, 800);
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const addressEl = form.querySelector('#address');
      const emailEl = form.querySelector('#email');
      const phoneEl = form.querySelector('#phone');

      const address = addressEl?.value.trim() || '';
      const email = emailEl?.value.trim() || '';
      const phone = phoneEl?.value.trim() || '';

      if (!address || !email) {
        alert('Please provide both address and email.');
        return;
      }

      const turnstileResponse = document.querySelector('[name="cf-turnstile-response"]');
      const token = turnstileResponse?.value || turnstileToken;

      if (!token) {
        alert('Please complete the security check.');
        return;
      }

      if (submitBtn) {
        submitBtn.disabled = true;
        buttonText?.classList.add('hidden');
        buttonLoading?.classList.remove('hidden');
      }
      successEl?.classList.add('hidden');
      errorEl?.classList.add('hidden');

      try {
        const res = await fetch('/api/lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            address,
            email,
            phone,
            turnstileToken: token,
            source: 'website',
            page: window.location.pathname,
          }),
        });

        if (res.ok) {
          successEl?.classList.remove('hidden');
          form.reset();
          turnstileToken = '';
          if (submitBtn) submitBtn.disabled = true;
          // @ts-ignore
          if (window.turnstile) window.turnstile.reset();
        } else {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.message || 'Submission failed');
        }
      } catch (err) {
        console.error(err);
        errorEl?.classList.remove('hidden');
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          buttonText?.classList.remove('hidden');
          buttonLoading?.classList.add('hidden');
        }
      }
    });
  })();
</script>